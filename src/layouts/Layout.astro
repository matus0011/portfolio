---
import "../styles/global.css";
import CustomCursor from "../components/CustomCursor.svelte";
import Loader from "../components/Loader.svelte";
import MenuOverlay from "../components/MenuOverlay.svelte";

interface Props {
  title?: string;
  lang?: "pl" | "en";
}
const { title = "Portfolio", lang = "pl" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,300;1,400&family=JetBrains+Mono:wght@400;500&family=Sofia+Sans+Condensed:ital,wght@0,100..900;1,100..900&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>

    <!-- Google Analytics 4 — zastąp G-XXXXXXXXXX swoim Measurement ID -->
    <script type="text/partytown" src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script type="text/partytown">
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script>
  </head>
  <body>
    <Loader client:load minDuration={1500} />
    <CustomCursor client:load />
    <slot />
    <MenuOverlay client:load {lang} />
  </body>
</html>
