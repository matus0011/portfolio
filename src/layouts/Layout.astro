---
import "../styles/global.css";
import CustomCursor from "../components/CustomCursor.svelte";
import CustomScrollbar from "../components/CustomScrollbar.svelte";
import Loader from "../components/Loader.svelte";
import MenuOverlay from "../components/MenuOverlay.svelte";

interface Props {
  title?: string;
  lang?: "pl" | "en";
}
const { title = "Portfolio", lang = "pl" } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Mona+Sans:ital,wght@0,200..900;1,200..900&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body>
    <Loader client:load minDuration={1500} />
    <CustomCursor client:load />
    <CustomScrollbar client:load />

    <!-- ScrollSmoother wymaga tej struktury -->
    <div id="smooth-wrapper">
      <div id="smooth-content">
        <!-- GLOBAL VERTICAL LINES -->
        <div
          data-speed="0.88"
          class="absolute top-0 bottom-0 left-[calc(50%-450px)] -translate-x-1/2 w-[1px] pointer-events-none z-40"
          style="background-color: var(--color-accent); opacity: 0.5; min-height: 100%;"
        ></div>
        <div
          data-speed="0.94"
          class="absolute top-0 bottom-0 left-[calc(50%-150px)] -translate-x-1/2 w-[1px] pointer-events-none z-40"
          style="background-color: var(--color-accent); opacity: 0.5; min-height: 100%;"
        ></div>
        <div
          data-speed="1.06"
          class="absolute top-0 bottom-0 left-[calc(50%+150px)] -translate-x-1/2 w-[1px] pointer-events-none z-40"
          style="background-color: var(--color-accent); opacity: 0.5; min-height: 100%;"
        ></div>
        <div
          data-speed="1.12"
          class="absolute top-0 bottom-0 left-[calc(50%+450px)] -translate-x-1/2 w-[1px] pointer-events-none z-40"
          style="background-color: var(--color-accent); opacity: 0.5; min-height: 100%;"
        ></div>

        <slot />
      </div>
    </div>

    <MenuOverlay client:load {lang} />

    <script>
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";
      import { ScrollSmoother } from "gsap/ScrollSmoother";

      gsap.registerPlugin(ScrollTrigger, ScrollSmoother);

      const smoother = ScrollSmoother.create({
        wrapper: "#smooth-wrapper",
        content: "#smooth-content",
        smooth: 1.5,
        effects: true,
      });

      // Udostępnij globalnie dla innych komponentów i powiadom o gotowości
      window.smoother = smoother;
      window.dispatchEvent(new CustomEvent("smootherReady"));
    </script>
  </body>
</html>

<style is:global>
  #smooth-wrapper {
    overflow: hidden;
    position: fixed;
    height: 100%;
    width: 100%;
    top: 0;
    left: 0;
  }

  #smooth-content {
    overflow: visible;
    width: 100%;
  }
</style>
