---
const tags = ["Artist", "Designer", "Creator"];
---

<section
  id="home"
  class="relative min-h-screen w-full overflow-hidden px-6 md:px-10 pt-32 pb-12"
  data-anim="hero"
>
  <!-- centered hero image -->
  <div
    class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[min(36vw,420px)] aspect-[3/4] overflow-hidden rounded-md z-10"
    data-anim="hero-img-wrap"
  >
    <img
      src="/images/hero.webp"
      alt="Ricky Dyson"
      class="w-full h-full object-cover"
      data-anim="hero-img"
    />
  </div>

  <!-- huge layered title -->
  <h1
    class="display-mega text-[16.875vw] select-none pointer-events-none relative"
    data-anim="hero-title"
  >
    <span class="block reveal-mask"><span>R</span></span>
    <span class="block reveal-mask text-right pr-[24vw] md:pr-[18vw]"><span>i</span></span>
    <span class="block reveal-mask"><span>cky</span></span>
    <span class="block reveal-mask text-right"><span>Dyson</span></span>
  </h1>

  <!-- tags vertical right -->
  <ul
    class="absolute right-6 md:right-10 top-1/2 -translate-y-1/2 hidden md:flex flex-col items-end gap-3 z-20"
    data-anim="hero-tags"
  >
    {
      tags.map((t) => (
        <li class="uplabel">{t}</li>
      ))
    }
  </ul>

  <!-- scroll prompt -->
  <div class="mt-8 flex justify-center" data-anim="hero-scroll">
    <span class="uplabel text-muted">(Scroll to explore)</span>
  </div>
</section>
