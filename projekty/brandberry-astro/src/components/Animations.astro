<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const init = () => {
    // Hero entrance
    const heroTitleSpans = document.querySelectorAll(
      "[data-anim='hero-title'] .reveal-mask > span"
    );
    const heroImg = document.querySelector("[data-anim='hero-img']");
    const heroImgWrap = document.querySelector("[data-anim='hero-img-wrap']");
    const heroTags = document.querySelectorAll("[data-anim='hero-tags'] li");
    const heroScroll = document.querySelector("[data-anim='hero-scroll']");

    const tl = gsap.timeline({ defaults: { ease: "expo.out" } });
    if (heroImgWrap)
      tl.fromTo(
        heroImgWrap,
        { scale: 0.6, opacity: 0 },
        { scale: 1, opacity: 1, duration: 1.6 },
        0
      );
    if (heroImg)
      tl.fromTo(heroImg, { scale: 1.3 }, { scale: 1, duration: 1.6 }, 0);
    if (heroTitleSpans.length)
      tl.to(
        heroTitleSpans,
        { y: "0%", duration: 1.1, stagger: 0.08 },
        0.2
      );
    if (heroTags.length)
      tl.fromTo(
        heroTags,
        { x: 30, opacity: 0 },
        { x: 0, opacity: 1, duration: 0.8, stagger: 0.08 },
        0.8
      );
    if (heroScroll)
      tl.fromTo(
        heroScroll,
        { y: 20, opacity: 0 },
        { y: 0, opacity: 1, duration: 0.8 },
        1.1
      );

    // Hero image parallax + scale-out on scroll
    if (heroImgWrap) {
      gsap.to(heroImgWrap, {
        yPercent: -20,
        scale: 1.1,
        ease: "none",
        scrollTrigger: {
          trigger: "[data-anim='hero']",
          start: "top top",
          end: "bottom top",
          scrub: true,
        },
      });
    }

    // Intro word-by-word fade
    const intro = document.querySelector("[data-split]");
    if (intro && intro.textContent) {
      const text = intro.textContent.trim();
      intro.innerHTML = text
        .split(/\s+/)
        .map(
          (w) =>
            `<span class="inline-block opacity-15 mr-[0.2em]">${w}</span>`
        )
        .join("");
      gsap.to(intro.querySelectorAll("span"), {
        opacity: 1,
        stagger: 0.04,
        ease: "none",
        scrollTrigger: {
          trigger: intro,
          start: "top 80%",
          end: "bottom 60%",
          scrub: true,
        },
      });
    }

    // Marquee rows — alternating direction, scroll nudges speed
    document.querySelectorAll<HTMLElement>("[data-marquee]").forEach((row) => {
      const distance = row.scrollWidth / 2;
      const reverse = row.dataset.reverse === "true";
      gsap.set(row, { x: reverse ? -distance : 0 });
      gsap.to(row, {
        x: reverse ? 0 : -distance,
        duration: 40,
        repeat: -1,
        ease: "none",
      });
    });

    // Project cards reveal
    document.querySelectorAll("[data-project]").forEach((el) => {
      gsap.fromTo(
        el,
        { y: 80, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 1.2,
          ease: "expo.out",
          scrollTrigger: { trigger: el, start: "top 85%" },
        }
      );
    });

    // Benefits reveal
    document.querySelectorAll("[data-benefit]").forEach((el) => {
      gsap.fromTo(
        el,
        { y: 40, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 1,
          ease: "expo.out",
          scrollTrigger: { trigger: el, start: "top 85%" },
        }
      );
    });

    // Heights title
    const heightsTitle = document.querySelector("[data-heights-title]");
    if (heightsTitle) {
      gsap.fromTo(
        heightsTitle,
        { y: 80, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 1.3,
          ease: "expo.out",
          scrollTrigger: { trigger: heightsTitle, start: "top 85%" },
        }
      );
    }

    // Awards rows
    document.querySelectorAll("[data-award]").forEach((el) => {
      gsap.fromTo(
        el,
        { x: -40, opacity: 0 },
        {
          x: 0,
          opacity: 1,
          duration: 0.9,
          ease: "expo.out",
          scrollTrigger: { trigger: el, start: "top 90%" },
        }
      );
    });

    // CTA scale-in
    const ctaTitle = document.querySelector("[data-cta-title]");
    if (ctaTitle) {
      gsap.fromTo(
        ctaTitle,
        { scale: 0.85, opacity: 0 },
        {
          scale: 1,
          opacity: 1,
          duration: 1.4,
          ease: "expo.out",
          scrollTrigger: { trigger: ctaTitle, start: "top 80%" },
        }
      );
    }

    // Footer title fade-in
    const footerTitle = document.querySelector("[data-anim='footer-title']");
    if (footerTitle) {
      gsap.fromTo(
        footerTitle,
        { y: 60, opacity: 0 },
        {
          y: 0,
          opacity: 1,
          duration: 1.4,
          ease: "expo.out",
          scrollTrigger: { trigger: footerTitle, start: "top 90%" },
        }
      );
    }
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>
