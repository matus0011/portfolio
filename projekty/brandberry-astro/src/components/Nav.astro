---
const links = [
  { label: "Home", href: "#home" },
  { label: "Work", href: "#work" },
  { label: "About", href: "#about" },
  { label: "Contact", href: "#contact" },
];
---

<header
  class="fixed top-0 left-0 right-0 z-50 px-6 md:px-10 py-5 mix-blend-difference text-paper"
  data-anim="nav"
>
  <nav class="flex items-center justify-between">
    <a href="#home" class="flex items-center gap-2 uplabel">
      <span class="inline-block w-2 h-2 rounded-full bg-paper"></span>
      Available May 2026
    </a>
    <ul class="hidden md:flex items-center gap-8 uplabel">
      {
        links.map((l) => (
          <li>
            <a href={l.href} class="relative group inline-block py-1">
              <span class="block overflow-hidden">
                <span class="block group-hover:-translate-y-full transition-transform duration-500">
                  {l.label}
                </span>
              </span>
              <span class="absolute inset-0 flex items-start pt-1 translate-y-full group-hover:translate-y-0 transition-transform duration-500">
                {l.label}
              </span>
            </a>
          </li>
        ))
      }
    </ul>
    <a
      href="#"
      class="uplabel inline-flex items-center gap-2"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
      Back
    </a>
  </nav>
</header>
