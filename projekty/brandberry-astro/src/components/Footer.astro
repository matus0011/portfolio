---
const socials = [
  { label: "Facebook", href: "#" },
  { label: "Instagram", href: "#" },
  { label: "X.com", href: "#" },
];
---

<footer class="bg-ink text-paper px-6 md:px-10 pt-16 md:pt-24 pb-8 relative z-10">
  <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-10">
    <ul class="flex flex-col gap-2 uplabel">
      {
        socials.map((s) => (
          <li>
            <a
              href={s.href}
              class="hover:opacity-60 transition-opacity inline-flex items-center gap-2"
            >
              {s.label}
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7V16"/></svg>
            </a>
          </li>
        ))
      }
    </ul>
    <a href="#home" class="uplabel inline-flex items-center gap-2 hover:opacity-60 transition-opacity">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
      back to top
    </a>
  </div>

  <!-- giant name repeat -->
  <h2 class="display-mega text-[18vw] md:text-[16vw] leading-[0.85] mt-12 select-none" data-anim="footer-title">
    <span class="block">R</span>
    <span class="block text-right pr-[20vw]">i</span>
    <span class="block">cky</span>
    <span class="block text-right">Dyson</span>
  </h2>

  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mt-12 pt-8 border-t border-paper/15 text-sm text-paper/60">
    <span>Designed by <a href="#" class="underline hover:text-paper">Treethemes</a>.</span>
    <ul class="flex flex-wrap gap-6 uplabel">
      <li><a href="#" class="hover:text-paper">Instructions</a></li>
      <li><a href="#" class="hover:text-paper">Style Guide</a></li>
      <li><a href="#" class="hover:text-paper">Licenses</a></li>
      <li><a href="#" class="hover:text-paper">Changelog</a></li>
    </ul>
  </div>
</footer>
