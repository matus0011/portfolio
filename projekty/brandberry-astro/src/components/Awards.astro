---
const rows = [
  { name: "Awwwards", title: "Site of the day", year: "2025" },
  { name: "Awwwards", title: "Developer Award", year: "2025" },
  { name: "The Webby Awards", title: "Site of the Month", year: "2024" },
  { name: "The FWA", title: "Site of the day", year: "2023" },
  { name: "Lovie Awards", title: "The Best Website", year: "2022" },
  { name: "Awwwards", title: "Honorable Mention", year: "2021" },
  { name: "CSS Design Awards", title: "Site of the day", year: "2021" },
];
---

<section class="px-6 md:px-10 py-24 md:py-32" data-anim="awards">
  <div class="mb-16 md:mb-24">
    <h2 class="display-mega text-[12vw] md:text-[8vw] leading-[0.85]">
      Awards /<br />Recognitions
    </h2>
  </div>

  <div class="grid grid-cols-12 uplabel text-muted border-b border-ink/15 pb-4">
    <span class="col-span-5">(Featured by)</span>
    <span class="col-span-5">(Award)</span>
    <span class="col-span-2 text-right">(Year)</span>
  </div>
  <ul>
    {
      rows.map((r) => (
        <li
          class="grid grid-cols-12 items-center border-b border-ink/15 py-6 md:py-7 group hover:bg-ink/[0.03] transition-colors"
          data-award
        >
          <span class="col-span-5 display text-2xl md:text-3xl">
            {r.name}
          </span>
          <span class="col-span-5 text-muted">{r.title}</span>
          <span class="col-span-2 text-right tabular-nums">{r.year}</span>
        </li>
      ))
    }
  </ul>
</section>
