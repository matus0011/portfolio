---
const projects = [
  {
    tags: ["Branding", "Design"],
    title: "Reimagining Reality",
    img: "/images/preview-1.webp",
  },
  {
    tags: ["Design"],
    title: "The First Brand",
    img: "/images/preview-2.webp",
  },
  {
    tags: ["Design", "Development"],
    title: "Medium Scene",
    img: "/images/preview-4.webp",
  },
];
---

<section id="work" class="px-6 md:px-10 py-24 md:py-32" data-anim="work">
  <div
    class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16 md:mb-24"
  >
    <h2 class="display-mega text-[12vw] md:text-[8vw]">Work</h2>
    <div class="flex flex-col text-right uplabel">
      <span>Projects of years</span>
      <span class="text-muted">©2021 — 2025</span>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-12 gap-y-24 gap-x-6">
    {
      projects.map((p, i) => (
        <a
          href="#"
          class={`group relative block col-span-12 md:col-span-6 ${i === 1 ? "md:col-start-7" : ""} ${i === 2 ? "md:col-span-8 md:col-start-3" : ""}`}
          data-project
        >
          <div class="overflow-hidden rounded-md aspect-[4/5] mb-6">
            <img
              src={p.img}
              alt={p.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            />
          </div>
          <div class="flex items-center justify-between">
            <div class="flex gap-4 uplabel text-muted">
              {p.tags.map((t) => (
                <span>{t}</span>
              ))}
            </div>
            <span class="inline-flex items-center justify-center w-10 h-10 rounded-full border border-ink/30 group-hover:bg-ink group-hover:text-paper group-hover:rotate-45 transition-all duration-500">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7V16"/></svg>
            </span>
          </div>
          <h3 class="display text-3xl md:text-5xl mt-3" data-project-title>
            {p.title}
          </h3>
        </a>
      ))
    }
  </div>

  <div class="mt-24 flex justify-center">
    <a href="#" class="group inline-flex items-center gap-3 uplabel border border-ink/30 rounded-full px-6 py-3 hover:bg-ink hover:text-paper transition-colors">
      All Projects
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H8M17 7V16"/></svg>
    </a>
  </div>
</section>
