---
import "../styles/global.css";
interface Props {
  title?: string;
}
const { title = "Dyson" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Mona+Sans:ital,wght@0,200..900;1,200..900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-paper text-ink relative min-h-screen">
    <!-- Background vertical lines -->
    <div class="pointer-events-none absolute inset-y-0 left-0 right-0 flex justify-between px-6 md:px-10 z-0">
      <div class="w-px h-full bg-ink/10 dark:bg-paper/10"></div>
      <div class="w-px h-full bg-ink/10 dark:bg-paper/10 hidden md:block"></div>
      <div class="w-px h-full bg-ink/10 dark:bg-paper/10 hidden md:block"></div>
      <div class="w-px h-full bg-ink/10 dark:bg-paper/10 hidden md:block"></div>
      <div class="w-px h-full bg-ink/10 dark:bg-paper/10"></div>
    </div>

    <div class="relative z-10">
      <slot />
    </div>
  </body>
</html>
