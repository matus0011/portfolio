		$this->add_control(
			'show_categories',
			[
				'label'        => esc_html__( 'Show Categories', 'brandberry' ),
				'type'         => Controls_Manager::SWITCHER,
				'label_on'     => esc_html__( 'Show', 'brandberry' ),
				'label_off'    => esc_html__( 'Hide', 'brandberry' ),
				'return_value' => 'yes',
